network:
  version: 2
  ethernets:
    enp7s0:
      dhcp4: true
  wifis:
    wlp6s0:
      dhcp4: false
      addresses:
        - 192.168.1.18/24
      routes:
        - to: default
          via: 192.168.1.1
      nameservers:
        addresses:
          - 8.8.8.8
          - 8.8.4.4
      access-points:
        "<YOUR_WIFI_SSID>":
          password: "<YOUR_WIFI_PASSWORD>"
